{$PUBLIC_SITE_HOST} {
  encode gzip zstd

  handle /v1/* {
    reverse_proxy api:4000
  }

  handle {
    reverse_proxy web:3000
  }
}

{$ADMIN_SITE_HOST} {
  encode gzip zstd

  handle /v1/* {
    reverse_proxy api:4000
  }

  handle {
    reverse_proxy admin:3001
  }
}

{$API_SITE_HOST} {
  encode gzip zstd
  reverse_proxy api:4000
}
