# Shared
NODE_ENV=production

# Public domains
PUBLIC_SITE_HOST=staging.egitimgurmesi.com
ADMIN_SITE_HOST=admin-staging.egitimgurmesi.com
API_SITE_HOST=api-staging.egitimgurmesi.com

PUBLIC_APP_URL=https://staging.egitimgurmesi.com
ADMIN_APP_URL=https://admin-staging.egitimgurmesi.com
API_APP_URL=http://api:4000
NEXT_PUBLIC_API_BASE_URL=/v1

# Database
DATABASE_URL=postgresql://ega:replace-me@postgres:5432/ega_staging
DIRECT_URL=postgresql://ega:replace-me@postgres:5432/ega_staging
POSTGRES_DB=ega_staging
POSTGRES_USER=ega
POSTGRES_PASSWORD=replace-me

# Cache
REDIS_URL=redis://redis:6379

# Authentication
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_DOMAIN=staging.egitimgurmesi.com
BOOTSTRAP_ADMIN_SECRET=replace-with-a-long-bootstrap-secret

# Email
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@staging.egitimgurmesi.com
EMAIL_FROM_NAME=Eğitim Gurmesi Akademi
EMAIL_REPLY_TO=destek@staging.egitimgurmesi.com
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-me
SMTP_PASSWORD=replace-me

# Payments
PAYMENT_PROVIDER=paytr
PAYMENT_MERCHANT_ID=replace-me
PAYMENT_API_KEY=replace-me
PAYMENT_SECRET_KEY=replace-me
PAYMENT_BASE_URL=https://www.paytr.com

# Unikazan
UNIKAZAN_API_BASE_URL=https://api.kazanuni.com
UNIKAZAN_API_KEY=replace-me
UNIKAZAN_PROJECT_KEY=replace-me
UNIKAZAN_ADMIN_KEY=replace-me
UNIKAZAN_WEBHOOK_SECRET=replace-me

# Media
MUX_TOKEN_ID=replace-me
MUX_TOKEN_SECRET=replace-me
MUX_WEBHOOK_SECRET=replace-me
MEDIA_STORAGE_DIR=/app/storage/media
MEDIA_PUBLIC_BASE_URL=https://api-staging.egitimgurmesi.com/v1
MEDIA_MAX_UPLOAD_BYTES=52428800

# WhatsApp
WHATSAPP_PHONE_E164=905xxxxxxxxx
WHATSAPP_DEFAULT_MESSAGE=Merhaba%2C%20paketler%20hakkinda%20bilgi%20almak%20istiyorum.
