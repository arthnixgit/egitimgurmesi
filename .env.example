# Shared
NODE_ENV=development

# Domains
PUBLIC_APP_URL=http://localhost:3000
ADMIN_APP_URL=http://localhost:3001
API_APP_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ega
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/ega

# Cache
REDIS_URL=redis://localhost:6379

# Authentication
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_DOMAIN=localhost
BOOTSTRAP_ADMIN_SECRET=replace-with-a-long-bootstrap-secret

# Email
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@example.com
EMAIL_API_KEY=replace-me

# Local Payments
PAYMENT_PROVIDER=iyzico
PAYMENT_API_KEY=replace-me
PAYMENT_SECRET_KEY=replace-me
PAYMENT_BASE_URL=https://sandbox-api.example.com

# Unikazan Coaching Redirect
UNIKAZAN_API_BASE_URL=https://api.kazanuni.com
UNIKAZAN_API_KEY=replace-me
UNIKAZAN_PROJECT_KEY=replace-me
UNIKAZAN_ADMIN_KEY=replace-me
UNIKAZAN_WEBHOOK_SECRET=replace-me

# Media
MUX_TOKEN_ID=replace-me
MUX_TOKEN_SECRET=replace-me
MUX_WEBHOOK_SECRET=replace-me

# WhatsApp
WHATSAPP_PHONE_E164=905xxxxxxxxx
WHATSAPP_DEFAULT_MESSAGE=Merhaba%2C%20paketler%20hakkinda%20bilgi%20almak%20istiyorum.
