# Shared
NODE_ENV=production
WEB_PORT=3000
ADMIN_PORT=3001
API_PORT=4000

# Public domains
PUBLIC_SITE_HOST=egitimgurmesi.com
ADMIN_SITE_HOST=admin.egitimgurmesi.com
API_SITE_HOST=api.egitimgurmesi.com

PUBLIC_APP_URL=https://egitimgurmesi.com
ADMIN_APP_URL=https://admin.egitimgurmesi.com
API_APP_URL=http://api:4000
NEXT_PUBLIC_API_BASE_URL=/v1
CORS_ORIGINS=https://egitimgurmesi.com,https://www.egitimgurmesi.com,https://admin.egitimgurmesi.com

# Database
DATABASE_URL=postgresql://ega:replace-me@postgres:5432/ega_production
DIRECT_URL=postgresql://ega:replace-me@postgres:5432/ega_production
POSTGRES_DB=ega_production
POSTGRES_USER=ega
POSTGRES_PASSWORD=replace-me

# Cache
REDIS_URL=redis://redis:6379

# Authentication
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_DOMAIN=egitimgurmesi.com
BOOTSTRAP_ADMIN_SECRET=replace-with-a-long-bootstrap-secret

# Email
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@egitimgurmesi.com
EMAIL_FROM_NAME=Egitim Gurmesi Akademi
EMAIL_REPLY_TO=destek@egitimgurmesi.com
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-me
SMTP_PASSWORD=replace-me

# Payments
PAYMENT_PROVIDER=paytr
PAYMENT_MERCHANT_ID=replace-me
PAYMENT_API_KEY=replace-me
PAYMENT_SECRET_KEY=replace-me
PAYMENT_BASE_URL=https://www.paytr.com

# Unikazan
UNIKAZAN_API_BASE_URL=https://api.kazanuni.com
UNIKAZAN_API_KEY=replace-me
UNIKAZAN_PROJECT_KEY=replace-me
UNIKAZAN_ADMIN_KEY=replace-me
UNIKAZAN_WEBHOOK_SECRET=replace-me

# Media
MEDIA_STORAGE_DIR=/app/storage/media
MEDIA_PUBLIC_BASE_URL=https://api.egitimgurmesi.com/v1
MEDIA_MAX_UPLOAD_BYTES=52428800

# WhatsApp
WHATSAPP_PHONE_E164=905xxxxxxxxx
WHATSAPP_DEFAULT_MESSAGE=Merhaba%2C%20paketler%20hakkinda%20bilgi%20almak%20istiyorum.

# Admin-triggered GitHub deploy status/dispatch
DEPLOY_ENABLED=false
DEPLOY_GITHUB_REPOSITORY=owner/repo
DEPLOY_GITHUB_BRANCH=production
DEPLOY_GITHUB_WORKFLOW_ID=deploy-vds.yml
DEPLOY_GITHUB_TOKEN=replace-with-github-token
