  updatedAt            DateTime             @updatedAt
  organization         Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch               Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  classGroup           ClassGroup?          @relation(fields: [classGroupId], references: [id], onDelete: SetNull)
  createdBy            StaffUser?           @relation("AnnouncementsCreated", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)
  reads                AnnouncementRead[]

  @@index([organizationId, branchId, status, publishAt])
  @@index([classGroupId, status, publishAt])
  @@map("announcements")
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  userId         String?
  staffUserId    String?
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User?        @relation("UserAnnouncementReads", fields: [userId], references: [id], onDelete: Cascade)
  staffUser      StaffUser?   @relation("StaffAnnouncementReads", fields: [staffUserId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@unique([announcementId, staffUserId])
  @@index([userId, readAt])
  @@index([staffUserId, readAt])
  @@map("announcement_reads")
}

model CoachingPlan {
  id                   String             @id @default(cuid())
  organizationId       String?
  branchId             String?
  userId               String
  coachStaffUserId     String?
  createdByStaffUserId String?
  title                String
  summary              String?
  weekStartsAt         DateTime?
  weekEndsAt           DateTime?
  goals                Json?
  status               CoachingPlanStatus @default(ACTIVE)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organization         Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch               Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  student              User               @relation("StudentCoachingPlans", fields: [userId], references: [id], onDelete: Cascade)
  coach                StaffUser?         @relation("CoachingPlanCoach", fields: [coachStaffUserId], references: [id], onDelete: SetNull)
  createdBy            StaffUser?         @relation("CoachingPlansCreated", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, branchId, status])
  @@index([userId, status])
  @@index([coachStaffUserId, status])
  @@map("coaching_plans")
}

model CoachingNote {
  id                   String        @id @default(cuid())
  organizationId       String?
  branchId             String?
  userId               String
  coachStaffUserId     String?
  createdByStaffUserId String?
  title                String
  body                 String
  followUpAt           DateTime?
  isPrivate            Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  organization         Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch               Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  student              User          @relation("StudentCoachingNotes", fields: [userId], references: [id], onDelete: Cascade)
  coach                StaffUser?    @relation("CoachingNoteCoach", fields: [coachStaffUserId], references: [id], onDelete: SetNull)
  createdBy            StaffUser?    @relation("CoachingNotesCreated", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, branchId, createdAt])
  @@index([userId, createdAt])
  @@index([coachStaffUserId, createdAt])
  @@map("coaching_notes")
}

model WhatsAppLead {
  id                   String        @id @default(cuid())
  organizationId       String?
  branchId             String?
  userId               String?
  productId            String?
  status               LeadStatus    @default(NEW)
  sourcePage           String?
  phoneSnapshot        String?
  message              String?
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  handledAt            DateTime?
  handledByStaffUserId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  user                 User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  product              Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  organization         Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch               Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  handledBy            StaffUser?    @relation("HandledLeads", fields: [handledByStaffUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([organizationId, branchId, status])
  @@map("whatsapp_leads")
}

model AuditLog {
  id             String         @id @default(cuid())
  organizationId String?
  branchId       String?
  actorType      AuditActorType
  staffUserId    String?
  userId         String?
  action         String
  entityType     String
  entityId       String
  summary        String?
  beforeData     Json?
  afterData      Json?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime       @default(now())
  staffActor     StaffUser?     @relation("StaffAuditActor", fields: [staffUserId], references: [id], onDelete: SetNull)
  userActor      User?          @relation("UserAuditActor", fields: [userId], references: [id], onDelete: SetNull)
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch         Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorType, createdAt])
  @@index([organizationId, branchId, createdAt])
  @@map("audit_logs")
}
