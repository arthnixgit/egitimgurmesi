generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum StaffStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum GradeLevel {
  GRADE_5
  GRADE_6
  GRADE_7
  GRADE_8
  GRADE_9
  GRADE_10
  GRADE_11
  GRADE_12
  GRADUATE
  UNIVERSITY
  OTHER
}

enum StudyTrack {
  SAYISAL
  SOZEL
  ESIT_AGIRLIK
  DIL
  TYT
  LGS
  MSU
  ARA_SINIF
  KPSS
  OTHER
}

enum ProductType {
  VIDEO_PACKAGE
  COACHING_PACKAGE
  HYBRID_PACKAGE
  DIGITAL_RESOURCE
}

enum ExternalProvider {
  LOCAL
  UNIKAZAN
}

enum ProductVideoSourceType {
  DIRECT
  EMBED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NavigationMenuLocation {
  PRIMARY
  FOOTER
  MOBILE
}

enum MarketingPageType {
  HOME
  LANDING
  DIRECTORY
  CONTENT
  LEGAL
}

enum FreeMaterialItemType {
  TOOL
  LINK
  PDF
  GUIDANCE
  EXTERNAL
}

enum MediaAssetKind {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  BRANDING
  OTHER
}

enum MediaAssetSourceType {
  LOCAL_UPLOAD
  EXTERNAL_URL
}

enum Currency {
  TRY
  USD
  EUR
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  REDIRECT_PENDING
  AWAITING_CONFIRMATION
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  LOCAL_GATEWAY
  UNIKAZAN
  MANUAL
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  EXTERNAL_REDIRECT
  FREE
}

enum PaymentStatus {
  INITIATED
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentAttemptType {
  CHECKOUT_INITIATED
  REDIRECT_CREATED
  REDIRECT_RETURN
  WEBHOOK
  STATUS_SYNC
  MANUAL_REVIEW
}

enum PaymentAttemptStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum ExternalProviderOrderStatus {
  CREATED
  REDIRECT_READY
  REDIRECTED
  RETURNED_SUCCESS
  RETURNED_FAILURE
  CONFIRMED
  FAILED
  CANCELLED
}

enum EnrollmentStatus {
  ACTIVE
  SCHEDULED
  EXPIRED
  CANCELLED
}

enum LessonType {
  VIDEO
  DOCUMENT
  LIVE_SESSION
  QUIZ
  ASSIGNMENT
}

enum LessonResourceType {
  PDF
  LINK
  DOWNLOAD
}

enum VideoProvider {
  MUX
  VIMEO
  EXTERNAL
}

enum VideoAssetStatus {
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

enum AuditActorType {
  STAFF_USER
  USER
  SYSTEM
}

enum AuthActorType {
  USER
  STAFF
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum BranchStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum BranchMembershipStatus {
  ACTIVE
  SUSPENDED
  LEFT
}

enum StaffBranchRole {
  BRANCH_ADMIN
  INSTRUCTOR
  COACH
  ACCOUNTANT
  STAFF
}

enum ClassGroupStatus {
  ACTIVE
  ARCHIVED
}

enum ClassGroupStudentStatus {
  ACTIVE
  LEFT
}

enum LiveSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum LiveSessionParticipantStatus {
  INVITED
  ATTENDED
  MISSED
  EXCUSED
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementAudience {
  ALL
  STAFF
  STUDENTS
  BRANCH_ADMINS
  INSTRUCTORS
  COACHES
  ACCOUNTANTS
}

enum CoachingPlanStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum IntegrationProvider {
  PAYTR
  UNIKAZAN
  OPENAI
  GOOGLE_DRIVE
  OTHER
}

model Organization {
  id                     String                    @id @default(cuid())
  slug                   String                    @unique
  name                   String
  legalName              String?
  status                 OrganizationStatus        @default(ACTIVE)
  taxNumber              String?
  supportEmail           String?
  supportPhone           String?
  metadata               Json?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  educationCenters       EducationCenter[]
  branches               Branch[]
  users                  User[]                    @relation("OrganizationUsers")
  staffUsers             StaffUser[]               @relation("OrganizationStaffUsers")
  branchStaffAssignments BranchStaffAssignment[]
  studentMemberships     StudentBranchMembership[]
  classGroups            ClassGroup[]
  classGroupStudents     ClassGroupStudent[]
  instructorAssignments  InstructorAssignment[]
  coachAssignments       CoachAssignment[]
  liveSessions           LiveSession[]
  announcements          Announcement[]
  coachingPlans          CoachingPlan[]
  coachingNotes          CoachingNote[]
  productCategories      ProductCategory[]
  products               Product[]
  orders                 Order[]
  payments               Payment[]
  courses                Course[]
  enrollments            Enrollment[]
  mediaAssets            MediaAsset[]
  leads                  WhatsAppLead[]
  auditLogs              AuditLog[]
  featureFlags           FeatureFlag[]
  tenantSettings         TenantSetting[]
  integrationCredentials IntegrationCredential[]

  @@map("organizations")
}

model EducationCenter {
  id             String       @id @default(cuid())
  organizationId String
  slug           String
  name           String
  legalName      String?
  centerType     String?
  city           String?
  district       String?
  address        String?
  phone          String?
  email          String?
  status         BranchStatus @default(ACTIVE)
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branches       Branch[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("education_centers")
}

model Branch {
  id                     String                    @id @default(cuid())
  organizationId         String
  educationCenterId      String?
  slug                   String
  name                   String
  code                   String?
  status                 BranchStatus              @default(ACTIVE)
  city                   String?
  district               String?
  address                String?
  phone                  String?
  email                  String?
  metadata               Json?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  organization           Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  educationCenter        EducationCenter?          @relation(fields: [educationCenterId], references: [id], onDelete: SetNull)
  primaryStudents        User[]                    @relation("PrimaryBranchStudents")
  primaryStaff           StaffUser[]               @relation("PrimaryBranchStaff")
  staffAssignments       BranchStaffAssignment[]
  studentMemberships     StudentBranchMembership[]
  classGroups            ClassGroup[]
  classGroupStudents     ClassGroupStudent[]
  instructorAssignments  InstructorAssignment[]
  coachAssignments       CoachAssignment[]
  liveSessions           LiveSession[]
  announcements          Announcement[]
  coachingPlans          CoachingPlan[]
  coachingNotes          CoachingNote[]
  productCategories      ProductCategory[]
  products               Product[]
  orders                 Order[]
  payments               Payment[]
  courses                Course[]
  enrollments            Enrollment[]
  mediaAssets            MediaAsset[]
  leads                  WhatsAppLead[]
  auditLogs              AuditLog[]
  featureFlags           FeatureFlag[]
  tenantSettings         TenantSetting[]
  integrationCredentials IntegrationCredential[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([educationCenterId])
  @@map("branches")
}

model BranchStaffAssignment {
  id                    String          @id @default(cuid())
  organizationId        String
  branchId              String
  staffUserId           String
  roleKey               StaffBranchRole
  isPrimary             Boolean         @default(false)
  permissionsOverride   Json?
  assignedByStaffUserId String?
  assignedAt            DateTime        @default(now())
  revokedAt             DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch                Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  staffUser             StaffUser       @relation("StaffBranchAssignments", fields: [staffUserId], references: [id], onDelete: Cascade)
  assignedBy            StaffUser?      @relation("BranchStaffAssignmentsMade", fields: [assignedByStaffUserId], references: [id], onDelete: SetNull)

  @@unique([staffUserId, branchId, roleKey])
  @@index([organizationId, branchId])
  @@index([staffUserId, revokedAt])
  @@map("branch_staff_assignments")
}

model StudentBranchMembership {
  id             String                 @id @default(cuid())
  organizationId String
  branchId       String
  userId         String
  status         BranchMembershipStatus @default(ACTIVE)
  isPrimary      Boolean                @default(false)
  joinedAt       DateTime               @default(now())
  leftAt         DateTime?
  metadata       Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([organizationId, branchId, status])
  @@index([userId, status])
  @@map("student_branch_memberships")
}

model ClassGroup {
  id                    String                 @id @default(cuid())
  organizationId        String
  branchId              String
  slug                  String
  name                  String
  description           String?
  gradeLevel            GradeLevel?
  studyTrack            StudyTrack?
  status                ClassGroupStatus       @default(ACTIVE)
  startsAt              DateTime?
  endsAt                DateTime?
  createdByStaffUserId  String?
  metadata              Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch                Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy             StaffUser?             @relation("ClassGroupsCreated", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)
  students              ClassGroupStudent[]
  instructorAssignments InstructorAssignment[] @relation("ClassGroupInstructorAssignments")
  coachAssignments      CoachAssignment[]      @relation("ClassGroupCoachAssignments")
  liveSessions          LiveSession[]
  announcements         Announcement[]

  @@unique([branchId, slug])
  @@index([organizationId, branchId, status])
  @@map("class_groups")
}

model ClassGroupStudent {
  id             String                  @id @default(cuid())
  organizationId String
  branchId       String
  classGroupId   String
  userId         String
  status         ClassGroupStudentStatus @default(ACTIVE)
  joinedAt       DateTime                @default(now())
  leftAt         DateTime?
  metadata       Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  classGroup     ClassGroup              @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classGroupId, userId])
  @@index([organizationId, branchId, status])
  @@index([userId, status])
  @@map("class_group_students")
}

model InstructorAssignment {
  id                    String       @id @default(cuid())
  organizationId        String
  branchId              String
  staffUserId           String
  userId                String?
  classGroupId          String?
  assignedByStaffUserId String?
  startsAt              DateTime     @default(now())
  endsAt                DateTime?
  isActive              Boolean      @default(true)
  metadata              Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch                Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  instructor            StaffUser    @relation("InstructorStaffAssignments", fields: [staffUserId], references: [id], onDelete: Cascade)
  student               User?        @relation("StudentInstructorAssignments", fields: [userId], references: [id], onDelete: Cascade)
  classGroup            ClassGroup?  @relation("ClassGroupInstructorAssignments", fields: [classGroupId], references: [id], onDelete: Cascade)
  assignedBy            StaffUser?   @relation("InstructorAssignmentsMade", fields: [assignedByStaffUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, branchId, isActive])
  @@index([staffUserId, isActive])
  @@index([userId, isActive])
  @@index([classGroupId, isActive])
  @@map("instructor_assignments")
}

model CoachAssignment {
  id                    String       @id @default(cuid())
  organizationId        String
  branchId              String
  staffUserId           String
  userId                String?
  classGroupId          String?
  assignedByStaffUserId String?
  startsAt              DateTime     @default(now())
  endsAt                DateTime?
  isActive              Boolean      @default(true)
  metadata              Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch                Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  coach                 StaffUser    @relation("CoachStaffAssignments", fields: [staffUserId], references: [id], onDelete: Cascade)
  student               User?        @relation("StudentCoachAssignments", fields: [userId], references: [id], onDelete: Cascade)
  classGroup            ClassGroup?  @relation("ClassGroupCoachAssignments", fields: [classGroupId], references: [id], onDelete: Cascade)
  assignedBy            StaffUser?   @relation("CoachAssignmentsMade", fields: [assignedByStaffUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, branchId, isActive])
  @@index([staffUserId, isActive])
  @@index([userId, isActive])
  @@index([classGroupId, isActive])
  @@map("coach_assignments")
}

model FeatureFlag {
  id             String        @id @default(cuid())
  organizationId String?
  branchId       String?
  key            String
  name           String
  description    String?
  isEnabled      Boolean       @default(false)
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([organizationId, branchId, key])
  @@index([key, isEnabled])
  @@map("feature_flags")
}

model TenantSetting {
  id             String        @id @default(cuid())
  organizationId String?
  branchId       String?
  key            String
  label          String?
  value          Json?
  isSecret       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([organizationId, branchId, key])
  @@index([key])
  @@map("tenant_settings")
}

model IntegrationCredential {
  id               String              @id @default(cuid())
  organizationId   String?
  branchId         String?
  provider         IntegrationProvider
  key              String
  displayName      String
  encryptedPayload Json?
  metadata         Json?
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  organization     Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch           Branch?             @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([organizationId, branchId, provider, key])
  @@index([provider, isActive])
  @@map("integration_credentials")
}

model User {
  id                      String                    @id @default(cuid())
  organizationId          String?
  primaryBranchId         String?
  email                   String                    @unique
  phone                   String?                   @unique
  passwordHash            String
  status                  UserStatus                @default(PENDING_VERIFICATION)
  emailVerifiedAt         DateTime?
  lastLoginAt             DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  profile                 UserProfile?
  studentProfile          StudentProfile?
  orders                  Order[]
  enrollments             Enrollment[]
  whatsappLeads           WhatsAppLead[]
  sessions                AuthSession[]
  emailCodes              EmailVerificationCode[]
  passwordResets          PasswordResetToken[]
  externalAccounts        ExternalAccountLink[]
  auditLogs               AuditLog[]                @relation("UserAuditActor")
  organization            Organization?             @relation("OrganizationUsers", fields: [organizationId], references: [id], onDelete: SetNull)
  primaryBranch           Branch?                   @relation("PrimaryBranchStudents", fields: [primaryBranchId], references: [id], onDelete: SetNull)
  branchMemberships       StudentBranchMembership[]
  classGroupMemberships   ClassGroupStudent[]
  instructorAssignments   InstructorAssignment[]    @relation("StudentInstructorAssignments")
  coachAssignments        CoachAssignment[]         @relation("StudentCoachAssignments")
  liveSessionParticipants LiveSessionParticipant[]
  announcementReads       AnnouncementRead[]        @relation("UserAnnouncementReads")
  coachingPlans           CoachingPlan[]            @relation("StudentCoachingPlans")
  coachingNotes           CoachingNote[]            @relation("StudentCoachingNotes")

  @@index([organizationId])
  @@index([primaryBranchId])
  @@map("users")
}

model UserProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  firstName              String
  lastName               String
  city                   String?
  district               String?
  birthDate              DateTime?
  parentName             String?
  parentPhone            String?
  marketingConsent       Boolean   @default(false)
  kvkkConsentAt          DateTime?
  termsAcceptedAt        DateTime?
  distanceSalesConsentAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model StudentProfile {
  id             String      @id @default(cuid())
  userId         String      @unique
  gradeLevel     GradeLevel?
  studyTrack     StudyTrack?
  schoolName     String?
  targetExamYear Int?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model ExternalAccountLink {
  id             String           @id @default(cuid())
  userId         String
  provider       ExternalProvider
  externalUserId String?
  externalEmail  String?
  refreshToken   String
  metadata       Json?
  linkedAt       DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([provider, externalEmail])
  @@map("external_account_links")
}

model StaffUser {
  id                        String                  @id @default(cuid())
  organizationId            String?
  primaryBranchId           String?
  email                     String                  @unique
  passwordHash              String?
  firstName                 String
  lastName                  String
  status                    StaffStatus             @default(INVITED)
  inviteAcceptedAt          DateTime?
  lastLoginAt               DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  roles                     StaffUserRole[]         @relation("AssignedRoles")
  roleAssignmentsMade       StaffUserRole[]         @relation("RoleAssignmentsMade")
  auditLogs                 AuditLog[]              @relation("StaffAuditActor")
  handledLeads              WhatsAppLead[]          @relation("HandledLeads")
  authoredCourses           Course[]                @relation("CoursesCreated")
  mediaAssetsCreated        MediaAsset[]            @relation("MediaAssetsCreated")
  sessions                  AuthSession[]
  organization              Organization?           @relation("OrganizationStaffUsers", fields: [organizationId], references: [id], onDelete: SetNull)
  primaryBranch             Branch?                 @relation("PrimaryBranchStaff", fields: [primaryBranchId], references: [id], onDelete: SetNull)
  branchAssignments         BranchStaffAssignment[] @relation("StaffBranchAssignments")
  branchAssignmentsMade     BranchStaffAssignment[] @relation("BranchStaffAssignmentsMade")
  classGroupsCreated        ClassGroup[]            @relation("ClassGroupsCreated")
  instructorAssignments     InstructorAssignment[]  @relation("InstructorStaffAssignments")
  instructorAssignmentsMade InstructorAssignment[]  @relation("InstructorAssignmentsMade")
  coachAssignments          CoachAssignment[]       @relation("CoachStaffAssignments")
  coachAssignmentsMade      CoachAssignment[]       @relation("CoachAssignmentsMade")
  liveSessionsCreated       LiveSession[]           @relation("LiveSessionsCreated")
  liveSessionsAsInstructor  LiveSession[]           @relation("LiveSessionInstructor")
  liveSessionsAsCoach       LiveSession[]           @relation("LiveSessionCoach")
  announcementsCreated      Announcement[]          @relation("AnnouncementsCreated")
  announcementReads         AnnouncementRead[]      @relation("StaffAnnouncementReads")
  coachingPlansCreated      CoachingPlan[]          @relation("CoachingPlansCreated")
  coachingPlansAsCoach      CoachingPlan[]          @relation("CoachingPlanCoach")
  coachingNotesCreated      CoachingNote[]          @relation("CoachingNotesCreated")
  coachingNotesAsCoach      CoachingNote[]          @relation("CoachingNoteCoach")

  @@index([organizationId])
  @@index([primaryBranchId])
  @@map("staff_users")
}

model Role {
  id               String           @id @default(cuid())
  key              String           @unique
  name             String
  description      String?
  isSystem         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  permissions      RolePermission[]
  staffAssignments StaffUserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model StaffUserRole {
  id                    String     @id @default(cuid())
  staffUserId           String
  roleId                String
  assignedByStaffUserId String?
  assignedAt            DateTime   @default(now())
  staffUser             StaffUser  @relation("AssignedRoles", fields: [staffUserId], references: [id], onDelete: Cascade)
  role                  Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy            StaffUser? @relation("RoleAssignmentsMade", fields: [assignedByStaffUserId], references: [id], onDelete: SetNull)

  @@unique([staffUserId, roleId])
  @@map("staff_user_roles")
}

model AuthSession {
  id               String        @id @default(cuid())
  actorType        AuthActorType
  userId           String?
  staffUserId      String?
  sessionFamily    String        @unique
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  lastUsedAt       DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffUser        StaffUser?    @relation(fields: [staffUserId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([staffUserId, expiresAt])
  @@map("auth_sessions")
}

model EmailVerificationCode {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("email_verification_codes")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model NavigationMenu {
  id          String                 @id @default(cuid())
  key         String                 @unique
  name        String
  location    NavigationMenuLocation @default(PRIMARY)
  description String?
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  items       NavigationMenuItem[]

  @@map("navigation_menus")
}

model NavigationMenuItem {
  id          String               @id @default(cuid())
  menuId      String
  parentId    String?
  itemKey     String
  label       String
  href        String
