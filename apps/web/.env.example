# Optional app-local web env for isolated runs.
# The VPS deployment should normally source the root .env.production before PM2 starts.

NODE_ENV=production
PORT=3000
NEXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN.com
NEXT_PUBLIC_API_BASE_URL=https://api.YOUR_DOMAIN.com/v1
INTERNAL_API_BASE_URL=http://127.0.0.1:4000
NEXT_STATIC_EXPORT=0
