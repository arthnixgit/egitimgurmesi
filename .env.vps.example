# VPS / PM2 / Nginx production template.
# Copy this file to .env.production on the VPS and replace every placeholder.

# Runtime
NODE_ENV=production
WEB_PORT=3000
ADMIN_PORT=3001
API_PORT=4000

# Domains
PUBLIC_SITE_HOST=YOUR_DOMAIN.com
ADMIN_SITE_HOST=admin.YOUR_DOMAIN.com
API_SITE_HOST=api.YOUR_DOMAIN.com
PUBLIC_APP_URL=https://YOUR_DOMAIN.com
ADMIN_APP_URL=https://admin.YOUR_DOMAIN.com
API_APP_URL=https://api.YOUR_DOMAIN.com
INTERNAL_API_BASE_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_BASE_URL=https://api.YOUR_DOMAIN.com/v1
CORS_ORIGINS=https://YOUR_DOMAIN.com,https://www.YOUR_DOMAIN.com,https://admin.YOUR_DOMAIN.com

# PostgreSQL
DATABASE_URL=postgresql://ega:REPLACE_STRONG_DB_PASSWORD@127.0.0.1:5432/ega_production
DIRECT_URL=postgresql://ega:REPLACE_STRONG_DB_PASSWORD@127.0.0.1:5432/ega_production
POSTGRES_DB=ega_production
POSTGRES_USER=ega
POSTGRES_PASSWORD=REPLACE_STRONG_DB_PASSWORD

# Cache
REDIS_URL=redis://127.0.0.1:6379

# Authentication
AUTH_SECRET=REPLACE_64_PLUS_RANDOM_CHARS
AUTH_COOKIE_DOMAIN=.YOUR_DOMAIN.com
BOOTSTRAP_ADMIN_SECRET=REPLACE_64_PLUS_RANDOM_CHARS

# Email
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@YOUR_DOMAIN.com
EMAIL_FROM_NAME=Egitim Gurmesi Akademi
EMAIL_REPLY_TO=destek@YOUR_DOMAIN.com
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=REPLACE_SMTP_USER
SMTP_PASSWORD=REPLACE_SMTP_PASSWORD

# Payments - keep placeholders until PayTR credentials arrive.
PAYMENT_PROVIDER=paytr
PAYMENT_MERCHANT_ID=REPLACE_PAYTR_MERCHANT_ID
PAYMENT_API_KEY=REPLACE_PAYTR_MERCHANT_KEY
PAYMENT_SECRET_KEY=REPLACE_PAYTR_MERCHANT_SALT
PAYMENT_BASE_URL=https://www.paytr.com
PAYMENT_TEST_MODE=true

# Unikazan - keep placeholders until final API credentials arrive.
UNIKAZAN_API_BASE_URL=https://api.kazanuni.com
UNIKAZAN_API_KEY=REPLACE_UNIKAZAN_API_KEY
UNIKAZAN_PROJECT_KEY=REPLACE_UNIKAZAN_PROJECT_KEY
UNIKAZAN_ADMIN_KEY=REPLACE_UNIKAZAN_ADMIN_KEY
UNIKAZAN_WEBHOOK_SECRET=REPLACE_UNIKAZAN_WEBHOOK_SECRET
UNIKAZAN_PUBLIC_CATALOG_BASE_URL=
UNIKAZAN_PUBLIC_CATALOG_API_KEY=

# Media
MEDIA_STORAGE_DIR=/opt/egitim-gurmesi/storage/media
MEDIA_PUBLIC_BASE_URL=https://api.YOUR_DOMAIN.com/v1
MEDIA_MAX_UPLOAD_BYTES=52428800

# WhatsApp
WHATSAPP_PHONE_E164=905xxxxxxxxx
WHATSAPP_DEFAULT_MESSAGE=Merhaba%2C%20paketler%20hakkinda%20bilgi%20almak%20istiyorum.

# Admin-triggered GitHub deploy status/dispatch
DEPLOY_ENABLED=false
DEPLOY_GITHUB_REPOSITORY=owner/repo
DEPLOY_GITHUB_BRANCH=production
DEPLOY_GITHUB_WORKFLOW_ID=deploy-vds.yml
DEPLOY_GITHUB_TOKEN=REPLACE_GITHUB_TOKEN
